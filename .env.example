OPENAI_API_KEY=
OPENAI_NANO_MODEL=gpt-5.4-nano
OPENAI_MINI_MODEL=gpt-5.4-mini
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai
LLM_TIMEOUT_SEC=60

PARSER_PRIMARY=docling
PARSER_FALLBACK=marker
PERSIST_PARSED_MARKDOWN=true
ALLOW_NATIVE_FALLBACK=true
PARSER_QUALITY_MIN_SCORE=0.55

CHUNK_MAX_TOKENS=650
CHUNK_OVERLAP_TOKENS=80

RETRIEVAL_TOP_SECTIONS=8
RETRIEVAL_TOP_CHUNKS=8
RETRIEVAL_TOP_TABLES=5
RETRIEVAL_TABLE_WEIGHT=1.25
RETRIEVAL_BM25_WEIGHT=0.45
RETRIEVAL_DENSE_WEIGHT=0.55

ANSWER_MAX_CONTEXT_ITEMS=10
ANSWER_REQUIRE_CITATIONS=true
INSUFFICIENT_EVIDENCE_THRESHOLD=0.20
